    "@nuxt/ui": "4.5.1",
    "@nuxtjs/i18n": "10.2.3",
    "@tailwindcss/vite": "^4.2.1",
    "@unhead/vue": "^2.1.10",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "@vueuse/math": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "@vueuse/nuxt": "14.2.1",
    "eslint": "^10.0.2",
    "nuxt": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.95",

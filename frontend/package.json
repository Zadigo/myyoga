{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "build:all": "eslint . --ext .ts,.vue && pnpm run test --run && git push --tags && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "npx playwright test",
    "test:coverage": "vitest run --coverage",
    "lint:ox": "oxlint",
    "lint:ox-fix": "oxlint --fix",
    "lint:ox-init": "oxlint --init"
  },
  "dependencies": {
    "@nuxt/hints": "1.1.1",
    "@nuxt/scripts": "1.0.6",
    "@nuxt/ui": "4.7.1",
    "@unhead/vue": "^3.1.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "@vueuse/math": "^14.3.0",
    "@vueuse/motion": "^3.0.3",
    "nuxt": "^4.4.4",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.105",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/i18n": "10.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^25.6.1",
    "@vitest/ui": "4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/nuxt": "14.3.0",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
